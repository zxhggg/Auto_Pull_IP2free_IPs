# =========================
# IP2FREE Agent 配置模板
# =========================
# 用法：
# 1. 复制当前文件，重命名为 .env
# 2. 按需修改下面的配置项
# 3. 运行：python ip2free_agent.py
#
# 说明：
# - 支持写成 KEY=value
# - 也支持带引号：KEY="value"
# - 空行和以 # 开头的行会被忽略
# - .env 文件只在本地使用，不要提交到仓库


# =========================
# 1) 登录信息
# =========================
# IP2FREE 登录邮箱
IP2FREE_EMAIL=your-email@example.com

# IP2FREE 登录密码
# 如果密码里有空格，建议加引号
IP2FREE_PASSWORD=your-password


# =========================
# 2) 输出配置
# =========================
# Clash 配置输出目录
#
# 常见写法：
# - ./output                    当前项目下 output 文件夹
# - .                           当前项目根目录
# - C:\ProxyConfigs             Windows 绝对路径
# - /home/yourname/proxy        Linux/macOS 绝对路径
# - 留空                        默认输出到桌面 proxy 文件夹
IP2FREE_CONFIG_PATH=./output


# =========================
# 3) 活动奖励行为
# =========================
# 是否自动领取“可直接领取”的活动奖励
# 可选值：true / false
# 推荐：true
IP2FREE_AUTO_CLAIM_REWARDS=true

# 代理来源
# 可选值：free / activity / both
# - free：只拉取免费代理
# - activity：只拉取活动代理
# - both：两种都拉取
# 推荐：both
IP2FREE_PROXY_SOURCE=both

# 导出格式
# 可选值：yaml / txt
# - yaml：导出 Clash 配置文件 proxies.yaml
# - txt：导出纯文本代理列表 proxies.txt
# txt 格式示例：socks5://31.58.9.4:6077:qinlboxi:13txp426eu8r
# 推荐：yaml
IP2FREE_OUTPUT_FORMAT=yaml

# 只自动领取“任务名称包含指定文本”的任务
# 留空：不筛选，领取所有可直接领取的任务
# 示例：每天一次丨点击就送无限流量住宅代理
IP2FREE_ACTIVITY_TASK_NAME_CONTAINS=


# =========================
# 4) 参考示例
# =========================
# 如果你只想跑最常见配置，保留下面这种效果就够了：
# IP2FREE_EMAIL=your-email@example.com
# IP2FREE_PASSWORD=your-password
# IP2FREE_CONFIG_PATH=./output
# IP2FREE_AUTO_CLAIM_REWARDS=true
# IP2FREE_PROXY_SOURCE=both
# IP2FREE_OUTPUT_FORMAT=yaml
# IP2FREE_ACTIVITY_TASK_NAME_CONTAINS=
